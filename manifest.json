{
  "manifest_version": 2,
  "name": "RTL Chat Input",
  "version": "1.0.0",
  "description": "Right-aligns chat inputs and improves mixed Persian/English typing.",
  "permissions": [
    "storage",
    "<all_urls>"
  ],
  "browser_action": {
    "default_title": "RTL Chat Input",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "rtl-chat-input@example.local",
      "strict_min_version": "109.0"
    }
  }
}
